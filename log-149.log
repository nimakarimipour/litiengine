class de.gurkenlabs.litiengine.GameRandom {
@Nullable
  public <T> T choose(@Nullable Collection<T> coll) {
    if (coll == null || coll.isEmpty()) {
      return null;
    }

    int num = (this.nextInt(coll.size()));
    for (T t : coll) {
      if (--num < 0) {
        return t;
      }
    }

    return null;
}
}
