            coll1Box != null ? coll1Box.getMaxY() : m1.getBoundingBox().getMaxY();
        final double m2MaxY =
            coll2Box != null ? coll2Box.getMaxY() : m2.getBoundingBox().getMaxY();
            
        return Double.valueOf(m1MaxY).compareTo(m2MaxY);
}
