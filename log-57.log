      Intersection result = null;
      for (final ICollisionEntity otherEntity : this.getCollisionEntities()) {
        if (!canCollide(entity, otherEntity)) {
          continue;
        }
  
        Rectangle2D otherCollisionBox = otherEntity.getCollisionBox();
        if (otherCollisionBox == null) {
          return null;
        }
  
        if (GeometricUtilities.intersects(otherCollisionBox, rect)) {
          Rectangle2D intersection = otherCollisionBox.createIntersection(rect);
          if (result != null) {
            result =
                new Intersection(
                    intersection.createUnion(result),
                    ArrayUtilities.append(result.involvedEntities, otherEntity));
          } else {
            result = new Intersection(intersection, otherEntity);
          }
        }
      }
  
      return result;
