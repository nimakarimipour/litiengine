        if (GeometricUtilities.intersects(otherCollisionBox, rect)) {
          Rectangle2D intersection = otherCollisionBox.createIntersection(rect);
          if (result != null) {
            result =
                new Intersection(
                    intersection.createUnion(result),
                    ArrayUtilities.append(result.involvedEntities, otherEntity));
          } else {
            result = new Intersection(intersection, otherEntity);
          }
        }
