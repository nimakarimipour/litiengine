    } catch (InvalidTileLayerException e) {
      log.log(Level.SEVERE, e.getMessage(), e);
      return new ArrayList<>();
    }

    return this.tiles;
}protected boolean isInfinite() {
    return this.chunks != null && !this.chunks.isEmpty();
