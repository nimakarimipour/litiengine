          final ImageComponent cell =
              this.createNewEntry(
                  this.getX() + i * (this.getColumnWidth() + this.xOffset),
                  this.getY() + j * (this.getRowHeight() + this.yOffset),
                  this.getColumnWidth(),
                  this.getRowHeight(),
                  this.getBackground(),
                  "",
                  img);
          this.cells.add(cell);
        }
      }

      this.getComponents().addAll(this.cells);
      this.initialized = true;
    }

    super.prepare();
}
}
