        return;
      }
  
      IMouse mouse = Input.mouse();
      if (mouse != null) {
        this.navigating = mouse.isRightButtonPressed();
        if (this.navigating) {
          this.navigator.navigate(mouse.getMapLocation());
        }
      }
}
}
