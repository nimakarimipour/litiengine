          final double m1MaxY =
              coll1Box != null ? Nullability.castToNonnull(coll1.getCollisionBox(), "instance check done").getMaxY() : m1.getBoundingBox().getMaxY();
          final double m2MaxY =
              coll2Box != null ? coll2Box.getMaxY() : m2.getBoundingBox().getMaxY();
  
          return Double.valueOf(m1MaxY).compareTo(m2MaxY);
}
