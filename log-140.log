  public void prepare() {

    if (!initialized) {
      int imageCount = -1;

      for (int j = 0; j < this.getRows(); j++) {
        for (int i = 0; i < this.getColumns(); i++) {
          Image img;
          if (imageCount < this.getImages().size() - 1) {
            imageCount++;
            img = this.getImages().get(imageCount);
          } else {
            img = null;
