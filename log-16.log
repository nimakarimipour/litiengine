      final IEntity entity,
      final String text,
      final Sound typeSound,
      SpeechBubbleAppearance appearance,
      Font font) {
    this(entity, text, appearance, font);
    this.typeSound = typeSound;
}private SpeechBubble(
      final IEntity entity,
      final String text,
      @Nullable SpeechBubbleAppearance appearance,
      @Nullable Font font) {
