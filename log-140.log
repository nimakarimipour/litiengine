                  this.getColumnWidth(),
                  this.getRowHeight(),
                  this.getBackground(),
                  "",
                  img);
          this.cells.add(cell);
        }
      }

      this.getComponents().addAll(this.cells);
      this.initialized = true;
    }

    super.prepare();
}
