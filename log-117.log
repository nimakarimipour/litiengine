      // draw mouse tile info
      drawTileBoundingBox(g, map, Input.mouse().getMapLocation());
    }

    final MapRenderedEvent event = new MapRenderedEvent(g, map);
    for (MapRenderedListener cons : mapDebugListener) {
      cons.rendered(event);
    }
}
